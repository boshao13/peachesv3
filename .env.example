# Peaches Fitness Club — environment variables
# Copy to .env.local for local dev; set these in Vercel for production.

# Public site URL (used for metadataBase, canonical/OG URLs, sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://www.peachesfitnessclub.com

# Forms (contact/careers/newsletter) send via EmailJS CLIENT-SIDE — no server key needed.
# Account/service/template IDs are public by design and live in lib/emailjs.ts. To use a
# different account, edit that file (and add the prod domain to EmailJS → allowed origins).

# Mapbox — public token for the /contact map (NEXT_PUBLIC_ = exposed client-side, as before).
# IMPORTANT: rotate the old committed token and URL-restrict the new one to the prod domain (spec §13.3).
NEXT_PUBLIC_MAPBOX_API_KEY=

# Glofox branch id (booking/memberships). Already hardcoded in content/site.ts; documented here for reference.
# GLOFOX_BRANCH_ID=65d38d833aabb0e6490203b0
